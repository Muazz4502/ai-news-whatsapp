# Twitter/X API v2 (Free tier: https://developer.twitter.com)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Twilio WhatsApp (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio sandbox number (use whatsapp:+14155238886 for sandbox)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your WhatsApp number in E.164 format
TWILIO_WHATSAPP_TO=whatsapp:+1YOURNUMBER

# OpenAI API (for generating summaries)
OPENAI_API_KEY=your_openai_api_key_here

# Schedule (24h format, local time)
DAILY_SEND_TIME=10:00

# SQLite database path (created automatically)
DB_PATH=ai_news.db
